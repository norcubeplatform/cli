  "paths": {
    "/backup-policies": {
      "get": {
        "description": "List all backup policies for the organization.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/response.APIResponseWithPagination"
                    },
                    {
                      "properties": {
                        "list": {
                          "items": {
                            "$ref": "#/components/schemas/dto.BackupPolicy"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    }
                  ]
                }
              }
            },
            "description": "OK"
