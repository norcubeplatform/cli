          },
          "jobCreatedAt": {
            "example": "2023-10-01T11:00:00Z",
            "type": "string"
          },
          "jobDeletedAt": {
            "description": "Soft-deletion fields populated by the retention worker. JobDeletedAt\nis the wall-clock when the worker expired this backup; JobExpirationReason\nis one of \"age_exceeded\" | \"keep_last_n_exceeded\".",
            "example": "2026-05-01T03:00:00Z",
            "type": "string"
          },
          "jobDurationMs": {
            "example": 1500000,
            "type": "integer"
          },
          "jobErrorSummary": {
            "example": "Connection timeout",
            "type": "string"
          },
          "jobExpirationReason": {
            "example": "age_exceeded",
            "type": "string"
          },
          "jobFinishedAt": {
            "example": "2023-10-01T12:30:00Z",
            "type": "string"
          },
          "jobId": {
            "example": "dc70e90d-a49f-4333-9f33-54a27d18869e",
            "type": "string"
          },
          "jobScheduledFor": {
            "example": "2023-10-01T12:00:00Z",
            "type": "string"
          },
          "jobStartedAt": {
            "example": "2023-10-01T12:05:00Z",
            "type": "string"
          },
          "jobStatus": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.BackupJobStatus"
              }
            ],
            "example": "success"
          },
          "jobTrigger": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.BackupJobTrigger"
              }
            ],
            "example": "schedule"
          },
          "policyCompression": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.BackupPolicyEncryption"
              }
            ],
            "example": "gzip"
          },
          "policyEncryption": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.BackupPolicyEncryption"
              }
            ],
            "example": "aes256"
          },
          "policyId": {
            "example": "pc70e90d-a49f-4333-9f33-54a27d18869e",
            "type": "string"
          },
          "policyMethod": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.BackupPolicyMethod"
              }
            ],
            "example": "full"
          },
          "policyName": {
            "example": "Daily Backup",
            "type": "string"
          },
          "policyRetentionDays": {
            "example": 30,
            "type": "integer"
          }
        },
        "required": [
          "datasourceEngine",
          "datasourceId",
          "datasourceName",
          "destinationId",
          "destinationIsManaged",
          "destinationRegion",
          "jobBytesWritten",
          "jobCreatedAt",
          "jobId",
          "jobScheduledFor",
          "jobStatus",
          "jobTrigger",
          "policyCompression",
          "policyEncryption",
          "policyId",
          "policyMethod",
          "policyName",
          "policyRetentionDays"
        ],
        "type": "object"
      },
