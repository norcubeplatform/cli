{
  "components": {
    "schemas": {
      "constants.BackupJobStatus": {
        "enum": [
          "queued",
          "running",
          "failed",
          "success",
          "partial",
          "canceled"
        ],
        "type": "string",
        "x-enum-varnames": [
          "JobStatusQueued",
          "JobStatusRunning",
          "JobStatusFailed",
          "JobStatusSuccess",
          "JobStatusPartial",
          "JobStatusCanceled"
        ]
      },
      "constants.BackupJobTrigger": {
        "enum": [
          "manual",
          "schedule"
        ],
        "type": "string",
        "x-enum-varnames": [
          "JobTriggerManual",
          "JobTriggerSchedule"
        ]
      },
      "constants.BackupPolicyCompression": {
        "enum": [
          "gzip",
          "zstd",
          "none"
        ],
        "type": "string",
        "x-enum-varnames": [
          "CompressionGzip",
          "CompressionZstd",
          "CompressionNone"
        ]
      },
      "constants.BackupPolicyEncryption": {
        "enum": [
          "sse-kms",
          "sse-s3",
          "client-side",
          "none"
        ],
        "type": "string",
        "x-enum-varnames": [
          "EncryptionSSEKMS",
          "EncryptionSSES3",
          "EncryptionClientSide",
          "EncryptionNone"
        ]
      },
      "constants.BackupPolicyMethod": {
        "enum": [
          "logical_dump",
          "physical",
          "pitr"
        ],
        "type": "string",
        "x-enum-varnames": [
          "MethodLogicalDump",
          "MethodPhysical",
          "MethodPITR"
        ]
      },
      "constants.DatasourceCredentialMode": {
        "enum": [
          "connection_uri",
          "fields"
        ],
        "type": "string",
        "x-enum-varnames": [
          "CredentialModeURI",
          "CredentialModeFields"
        ]
      },
      "constants.DatasourceEngine": {
        "enum": [
          "postgres",
          "mongodb"
        ],
        "type": "string",
        "x-enum-varnames": [
          "EnginePostgres",
          "EngineMongoDB"
        ]
      },
      "constants.DatasourceEnvironment": {
        "enum": [
          "prod",
          "staging",
          "dev",
          "test"
        ],
        "type": "string",
        "x-enum-varnames": [
          "EnvironmentProd",
          "EnvironmentStaging",
          "EnvironmentDev",
          "EnvironmentTest"
        ]
      },
      "constants.DatasourceRegion": {
        "enum": [
          "eu-central-1"
        ],
        "type": "string",
        "x-enum-varnames": [
          "RegionEUCentral1"
        ]
      },
      "constants.StorageDestinationRegion": {
        "enum": [
          "eu-central-1"
        ],
        "type": "string",
        "x-enum-varnames": [
          "StorageDestinationRegionEUCentral1"
        ]
      },
      "datasourcehandler.payloadCreateRequest": {
        "properties": {
          "engine": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.DatasourceEngine"
              }
            ],
            "example": "postgres"
          },
          "environment": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.DatasourceEnvironment"
              }
            ],
            "example": "staging"
          },
          "name": {
            "example": "my-database",
            "type": "string"
          },
          "region": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.DatasourceRegion"
              }
            ],
            "example": "eu-central-1"
          }
        },
        "required": [
          "engine",
          "environment",
          "name",
          "region"
        ],
        "type": "object"
      },
      "datasourcehandler.payloadCreateResponse": {
        "properties": {
          "id": {
            "example": "9ac10aed-7c50-4afe-87ca-e5cc46bb29f2",
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "datasourcehandler.payloadCredentialFieldsDTO": {
        "properties": {
          "mongodb": {
            "$ref": "#/components/schemas/dsn.MongoFields"
          },
          "postgres": {
            "$ref": "#/components/schemas/dsn.PostgresFields"
          }
        },
        "type": "object"
      },
      "datasourcehandler.payloadDataSourcePolicyAttachRequest": {
        "properties": {
          "destinationId": {
            "example": "dc70e90d-a49f-4333-9f33-54a27d18869e",
            "type": "string"
          },
          "enabled": {
            "example": true,
            "type": "boolean"
          },
          "policyId": {
            "example": "a3bb189e-8bf9-3888-9912-ace4e6543002",
            "type": "string"
          },
          "priority": {
            "example": 3,
            "type": "integer"
          }
        },
        "required": [
          "destinationId",
          "enabled",
          "policyId"
        ],
        "type": "object"
      },
      "datasourcehandler.payloadDataSourcePolicyAttachResponse": {
        "properties": {
          "id": {
            "type": "string"
          }
        },
        "required": [
          "id"
        ],
        "type": "object"
      },
      "datasourcehandler.payloadDatasourcePolicyUpdateRequest": {
        "properties": {
          "enabled": {
            "description": "Enabled toggles the scheduler gate for this one attachment. The\nscheduler only enqueues jobs where attachment.enabled = true, so\nsetting this to false pauses just this policy on this data source\nwithout losing schedule history or detaching the policy.",
            "example": false,
            "type": "boolean"
          },
          "priority": {
            "description": "Priority orders concurrent attachments when multiple policies are\neligible to run on the same data source at the same minute.",
            "example": 50,
            "type": "integer"
          }
        },
        "type": "object"
      },
      "datasourcehandler.payloadDatasourceUpdateRequest": {
        "properties": {
          "environment": {
            "example": "production",
            "type": "string"
          },
          "isActive": {
            "description": "IsActive flips the master switch: false halts every backup policy\nattached to this data source (the scheduler skips data sources with\nis_active=false). Other fields above are simple metadata edits.",
            "example": false,
            "type": "boolean"
          },
          "name": {
            "example": "prod-postgres",
            "type": "string"
          },
          "region": {
            "example": "eu-central-1",
            "type": "string"
          }
        },
        "type": "object"
      },
      "datasourcehandler.payloadSetCredentialsRequest": {
        "properties": {
          "fields": {
            "$ref": "#/components/schemas/datasourcehandler.payloadCredentialFieldsDTO"
          },
          "mode": {
            "allOf": [
              {
                "$ref": "#/components/schemas/constants.DatasourceCredentialMode"
              }
            ],
            "example": "connection_uri"
          },
          "uri": {
            "example": "postgres://user:pass@host:5432/db?sslmode=require",
            "type": "string"
          }
        },
        "required": [
          "mode"
        ],
        "type": "object"
      },
      "datasourcehandler.payloadSetCredentialsResponse": {
        "properties": {
          "updatedAt": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "dsn.MongoFields": {
        "properties": {
          "authSource": {
            "type": "string"
          },
          "db": {
            "type": "string"
          },
          "hosts": {
            "description": "pro mongodb://",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "params": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "password": {
            "type": "string"
          },
          "replicaSet": {
            "type": "string"
          },
          "scheme": {
            "enum": [
              "mongodb",
              "mongodb+srv"
            ],
            "type": "string"
          },
          "srv_host": {
            "description": "pro +srv",
            "type": "string"
          },
          "tls": {
            "type": "boolean"
          },
          "user": {
            "type": "string"
          }
        },
        "required": [
          "db",
          "scheme"
        ],
        "type": "object"
      },
      "dsn.PostgresFields": {
        "properties": {
          "db": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "params": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object"
          },
          "password": {
            "description": "optional (může být v URI)",
            "type": "string"
          },
          "port": {
            "maximum": 65535,
            "minimum": 1,
            "type": "integer"
          },
          "sslmode": {
            "description": "require|verify-full|...",
            "type": "string"
          },
          "user": {
            "type": "string"
          }
        },
        "required": [
          "db",
          "host",
          "port",
          "user"
        ],
        "type": "object"
      },
      "dto.BackupJob": {
        "properties": {
          "datasourceEngine": {
